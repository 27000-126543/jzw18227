{
  "name": "git-visual-manager",
  "version": "1.0.0",
  "description": "本地Git仓库可视化管理桌面工具",
  "main": "dist-electron/main.js",
  "scripts": {
    "compile:electron": "tsc -p electron/tsconfig.json",
    "dev:renderer": "vite",
    "dev:electron": "node_modules\\electron\\dist\\electron.exe dist-electron/main.js",
    "dev": "npm run compile:electron && node scripts/fix-electron-path.js && concurrently -k \"npm:dev:renderer\" \"node scripts/wait-and-start-electron.js\"",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron && electron-builder",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.gitvisualmanager.app",
    "productName": "Git Visual Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ]
  }
}
